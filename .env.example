# Sanctum & Shadow — local dev environment
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
#   cp .env.example .env
#
# Then run:  node server.js      → http://localhost:3000
#
# Alternatively, skip .env entirely and let Railway inject the real vars:
#   railway link            (once, pick the sanctum-shadow project)
#   railway run node server.js

# Required for live AI narration (NPC dialogue + AI scenes) via /api/npc.
# Without it the game still runs on offline-narration.js fallbacks.
ANTHROPIC_API_KEY=

# Optional — enables /debug?key=... (returns 404 unless set and matching).
DEBUG_KEY=

# Optional — extra CORS origins, comma-separated.
ALLOWED_ORIGINS=
